{
	"Logging": {
		"LogLevel": {
			"Default": "Information",
			"Microsoft.AspNetCore": "Warning"
		}
	},
	"AllowedHosts": "*",
	"Migrations": {
		"ApplyOnStartup": false
	},
	"Jwt": {
		"Issuer": "CloudDrive",
		"Audience": "CloudDrive.Client",
		"AccessTokenLifetime": "00:15:00",
		"RefreshTokenLifetime": "30.00:00:00"
	},
	"RateLimiting": {
		"Login": {
			"PermitLimit": 5,
			"Window": "00:01:00"
		},
		"Register": {
			"PermitLimit": 3,
			"Window": "00:05:00"
		}
	}
}
