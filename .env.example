# Скопируйте в .env и подставьте свои значения.
# .env подхватывается docker compose автоматически из корня репозитория.

DB_DATABASE=<имя_базы_данных>
DB_USER=<имя_пользователя>
DB_PASSWORD=<пароль>

ConnectionStrings__CloudDrive=Host=clouddrive.database;Port=5432;Database=${DB_DATABASE};Username=${DB_USER};Password=${DB_PASSWORD}

# Base64-строка, декодирующая в не менее 32 байт (256 бит) - сгенерировать: openssl rand -base64 32
Jwt__SigningKey=<base64_ключ_не_короче_32_байт>
